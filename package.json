{
  "name": "@gridwork/siteaudit",
  "version": "1.0.0",
  "description": "MCP server that audits websites for accessibility (WCAG/EAA), performance, SEO, design quality, and mobile responsiveness",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gridwork-siteaudit": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "accessibility",
    "wcag",
    "eaa",
    "seo",
    "performance",
    "audit",
    "website"
  ],
  "author": "Gridwork <thegridwork@proton.me>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cheerio": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
